BasedOnStyle: Google  # 基于风格
Language: Cpp   # 指定语言为C++
AccessModifierOffset: -4  # 访问修饰符相对缩进偏移量（左4格）
AlignAfterOpenBracket: DontAlign  # 左括号后参数对齐
AlignConsecutiveAssignments: true  # 连续赋值的等号垂直对齐
AlignConsecutiveDeclarations: true  # 连续声明的类型和变量名垂直对齐
AlignConsecutiveMacros: true # 连续宏定义的对齐
AlignOperands: false  # 禁止操作数对齐以提高可读性
AlignTrailingComments: true  # 对齐行尾注释，使注释在同一列上
AlwaysBreakAfterReturnType: None  # 返回类型与函数名保持在同一行
AlwaysBreakTemplateDeclarations: Yes  # 模板声明总是换行
BinPackArguments: false  # 禁止参数打包，每个参数独立一行
BinPackParameters: false  # 尽可能将函数声明的参数压缩到最少行
SeparateDefinitionBlocks: Leave # 保留定义块之间（如类、函数等）的现有空行设置
DerivePointerAlignment: false # 禁止从现有代码推断指针位置
PointerAlignment: Left # 指针符号与类型左对齐
BraceWrapping: # 大括号换行规则
  AfterCaseLabel: true  # 在case标签后另起一行
  AfterClass: true  # 在类体开括号后另起一行
  AfterControlStatement: true  # 在控制语句开括号后另起一行
  AfterEnum: true  # 在枚举体开括号后另起一行
  AfterFunction: true  # 在函数定义开括号后另起一行
  AfterNamespace: true  # 在命名空间开括号后另起一行
  AfterStruct: true  # 在结构体开括号后另起一行
  AfterUnion: true  # 在联合体开括号后另起一行
  AfterExternBlock: true  # 在extern块开括号后另起一行
  BeforeCatch: true  # 在catch关键字前另起一行
  BeforeElse: true  # 在else关键字前另起一行
  BeforeLambdaBody: true  # 在lambda表达式体前另起一行
  BeforeWhile: true  # 在do-while循环的while前另起一行
  SplitEmptyFunction: true  # 将空函数体分为多行
  SplitEmptyRecord: true  # 将空记录类型分为多行
  SplitEmptyNamespace: true  # 将空命名空间分为多行
BreakBeforeBraces: Custom  # 大括号风格：附在语句同一行
BreakBeforeTernaryOperators: true  # 在三元运算符的问号和冒号前换行
BreakConstructorInitializers: AfterColon  # 构造函数初始化列表在冒号后换行
BreakConstructorInitializersBeforeComma: false  # 初始化列表中的逗号前不换行
ColumnLimit: 0  # 最大列宽
CompactNamespaces: false  # 命名空间之间保留空行
ConstructorInitializerAllOnOneLineOrOnePerLine: false  # 初始化列表不全部在一行或每项独立一行
ContinuationIndentWidth: 4  # 续行缩进宽度为4个空格
EmptyLineAfterAccessModifier: Leave  # 访问修饰符后空行保留
EmptyLineBeforeAccessModifier: Leave  # 访问修饰符前空行保留
SortIncludes: false # 不排序include文件
IndentCaseBlocks: true  # 缩进case块
IndentCaseLabels: false  # 不缩进case标签
IndentPPDirectives: None  # 不缩进预处理指令
IndentWidth: 4  # 缩进宽度为4个空格
IndentWrappedFunctionNames: false  # 不缩进换行的函数名
MacroBlockBegin: ''  # 宏定义开始标记
MacroBlockEnd: ''  # 宏定义结束标记
MaxEmptyLinesToKeep: 3  # 最多保留3个空行
SpacesInLineCommentPrefix:
  Minimum: 1
  Maximum: -1
NamespaceIndentation: None  # 命名空间内内容不缩进
SpaceAfterCStyleCast: false  # C风格强制转换后不加空格
SpaceAfterTemplateKeyword: true  # 模板关键字后加空格
SpaceBeforeAssignmentOperators: true  # 赋值运算符前加空格
SpaceBeforeInheritanceColon: true  # 继承冒号前加空格
SpaceBeforeParens: ControlStatements  # 控制语句的括号前加空格
SpaceBeforeRangeBasedForLoopColon: true  # 范围基于for循环的冒号前加空格
SpaceBeforeSquareBrackets: false  # 方括号前不加空格
SpaceInEmptyParentheses: false  # 空括号内不加空格
SpacesBeforeTrailingComments: 1  # 行尾注释前保留一个空格
SpacesInAngles: false  # 不在尖括号内侧添加空格
SpacesInConditionalStatement: false  # 不在条件语句内侧添加空格
SpacesInCStyleCastParentheses: false  # 不在C风格强制转换的括号内侧添加空格
SpacesInParentheses: false  # 不在普通括号内侧添加空格
SpacesInSquareBrackets: false  # 不在方括号内侧添加空格
TabWidth: 4  # 制表符宽度为4个空格
UseTab: Never  # 从不使用制表符
AllowShortIfStatementsOnASingleLine: Never  # 不允许短的if语句和单行
AllowShortBlocksOnASingleLine: true  # 不允许短代码块在一行
AllowShortFunctionsOnASingleLine: All  # 允许短函数在一行
AllowShortLambdasOnASingleLine: Empty  # lambda表达式是否允许在一行
# CommentPragmas: '^[^ ]'  # 注释和编译指令的格式（已禁用，以免阻止添加空格）
IndentExternBlock: NoIndent
AlignConsecutiveBitFields:
  Enabled: true
  AcrossEmptyLines: false  # 是否跨越空行对齐
  AcrossComments: true     # 是否跨越注释对齐
  AlignCompound: false     # 是否对齐复合表达式
  PadOperators: true       # 是否在冒号前后添加空格
AlignArrayOfStructures: Left
